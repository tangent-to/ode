{
  "name": "@tangent.to/ode",
  "version": "0.1.2",
  "description": "ODE integration for JavaScript (ESM): adaptive Dormand-Prince RK45, stiff Rosenbrock, dense output, event detection. scipy.integrate-validated.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build:browser",
    "test": "vitest",
    "test:run": "vitest run",
    "test:scipy": "uv run --with scipy python3 tests_compare-to-scipy/compare_with_scipy.py",
    "build:browser": "esbuild src/index.js --bundle --platform=browser --format=esm --target=es2020 --outfile=dist/index.js --sourcemap --minify --keep-names",
    "jsr:publish": "deno publish --allow-dirty",
    "jsr:publish:dry-run": "deno publish --dry-run --allow-dirty",
    "deno:check": "deno check src/index.js",
    "version": "node scripts/sync-version.mjs && git add deno.json"
  },
  "keywords": [
    "ode",
    "integration",
    "runge-kutta",
    "dormand-prince",
    "stiff",
    "differential-equations",
    "esm",
    "browser"
  ],
  "author": "Essi Parent",
  "license": "MIT",
  "homepage": "https://github.com/tangent-to/ode",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangent-to/ode"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@tangent.to/lina": "^0.1.2"
  }
}
